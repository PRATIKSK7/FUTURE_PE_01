# ==========================================
# COPYCRAFT AI - ENVIRONMENT VARIABLES
# ==========================================
# Duplicate this file as .env (for Next.js) and .env (for FastAPI) in their respective directories

# ------------------------------------------
# FRONTEND (Next.js - Vercel)
# ------------------------------------------
NEXT_PUBLIC_API_URL=https://api.copycraft.ai
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxx

# ------------------------------------------
# BACKEND (FastAPI - Render)
# ------------------------------------------
# Environment (development | staging | production)
ENV=production

# Database (Neon Serverless Postgres)
# Requires connection pooling enabled in Neon Dashboard
DATABASE_URL=postgresql://user:password@ep-cold-shadow-123456.us-east-2.aws.neon.tech/neondb?sslmode=require

# Clerk Backend Validation
CLERK_ISSUER_URL=https://clerk.copycraft.ai

# External APIs
GEMINI_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxxxxx

# Security
CORS_ORIGINS=https://copycraft.ai,https://www.copycraft.ai

# ------------------------------------------
# STORAGE ARCHITECTURE (Future Implementation)
# ------------------------------------------
STORAGE_PROVIDER=s3 # options: local, s3, cloudinary
